# Dockerfile for NFS Client with optional Fustor sensord
FROM python:3.11-slim

WORKDIR /app

# Install NFS client and system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    nfs-common \
    curl \
    procps \
    faketime \
    gettext-base \
    && rm -rf /var/lib/apt/lists/*

# Copy the entire monorepo (context is project root)
COPY sensord /app/sensord
COPY core /app/core
COPY sensord-sdk /app/sensord-sdk
COPY fusion-sdk /app/fusion-sdk
COPY extensions /app/extensions

# Set fake version for setuptools-scm (since .git is not copied)
ENV SETUPTOOLS_SCM_PRETEND_VERSION=0.1.0

# Install Fustor sensord and dependencies (all pip deps declared in package pyproject.toml)
RUN pip install --no-cache-dir \
    python-dotenv \
    /app/core \
    /app/sensord-sdk \
    /app/fusion-sdk \
    /app/extensions/schema-fs \
    /app/extensions/source-fs \
    /app/extensions/sender-http \
    /app/extensions/sender-echo \
    /app/sensord



# Create directories
RUN mkdir -p /mnt/shared /data/sensord

# Copy entrypoint script
COPY tests/e2e/containers/nfs-client/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
